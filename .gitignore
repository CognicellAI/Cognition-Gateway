# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ───────────────────────────────────────────────────────────────────
my-app/.next/
my-app/out/
my-app/build/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.db-journal
*.db-shm
*.db-wal

# ── Secrets & credentials — never commit ─────────────────────────────────────
.env
.env.*
!.env.example
*.pem

# ── Dev tooling artifacts ─────────────────────────────────────────────────────
.playwright-cli/
*.png
*.pdf
coverage/
.vercel/

# ── Python virtualenv ─────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc

# ── Build temp ────────────────────────────────────────────────────────────────
.npmrc-builds-tmp
skills-lock.json
-

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
